
[temp]
command=$I3SCRIPTS/i3temp
markup=pango
interval=5
separator_block_width=0

[cpu]
command=$I3SCRIPTS/i3cpu
markup=pango
interval=5
separator_block_width=0

[mem]
command=$I3SCRIPTS/i3mem
markup=pango
separator_block_width=0
interval=5


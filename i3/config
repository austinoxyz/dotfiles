# ~/.config/i3/config

set $mod Mod4
set $up k
set $down j
set $left h
set $right l
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"

set $sleep 0.2

# configure two monitor setup, adjust DP-[x] as needed
set $display_right DP-2
set $display_left DP-0
exec xrandr --output $display_left --primary --mode 1920x1080 --rate 144.00 --brightness 1 --gamma 1:1:1 --output $display_right --right-of $display_left --mode 1920x1080 --rate 60.00 --brightness 1 --gamma 1:1:1 --crtc 1
force_xinerama yes

# remove title from windows
for_window [class="^.*"] border pixel 2

# start specified applications floating
for_window [class="^GNU Image Manipulation Program$"] floating enable
for_window [class="^qBittorrent"] floating enable

for_window [class="^qBittorrent"] floating enable

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# audio control with volume keys on top row (F10, F11, F12 w/o Fn modifier)
bindsym XF86AudioRaiseVolume exec amixer -q -D pulse sset Master 5%+ && pkill -RTMIN+1 i3blocks
bindsym XF86AudioLowerVolume exec amixer -q -D pulse sset Master 5%- && pkill -RTMIN+1 i3blocks
bindsym XF86AudioMute exec amixer -q -D pulse sset Master toggle && pkill -RTMIN+1 i3blocks
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym $mod+Ctrl+$left move workspace $ws2
bindsym $mod+Ctrl+$right move workspace $ws2

bindsym $mod+Alt+$left focus output 

# use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# start a terminal
bindsym $mod+Return exec $TERMINAL

# kill focused window
bindsym $mod+Shift+q kill


# APPLICATIONS
bindsym $mod+0 exec --no-startup-id dmenu_run -i -m 1 -p "launch:" -fn "iosevka-11"

bindsym $mod+d exec --no-startup-id launch_app
bindsym $mod+s exec --no-startup-id launch_search
bindsym $mod+x exec --no-startup-id launch_cmd

bindsym $mod+Shift+o exec --no-startup-id launch_bookmark
bindsym $mod+b exec --no-startup-id launch_quick_bookmark
bindsym $mod+Shift+b exec --no-startup-id add_current_url_to_bookmarks



bindsym $mod+Shift+n exec --no-startup-id $TERMINAL -e 'nvim'
bindsym $mod+Shift+f exec --no-startup-id firefox
bindsym $mod+Shift+p exec --no-startup-id keepassxc
bindsym $mod+Shift+g exec --no-startup-id gimp
bindsym $mod+Shift+t exec --no-startup-id $TERMINAL -e 'chatgpt'
bindsym $mod+Shift+v exec --no-startup-id virt-manager

# mail
bindsym $mod+Shift+m exec --no-startup-id firefox -new-window "https://gmail.com"              

# change focus
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# move focused window
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# split in horizontal or vertical orientation
bindsym $mod+g split h
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
#bindsym $mod+p layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus scratchpad
bindsym $mod+Shift+minus move scratchpad

# show and focus next scratchpad or hide focused scratchpad.
bindsym $mod+minus scratchpad show

# switch to random wallpaper
bindsym $mod+Prior exec wal -i ${WALLPAPERS_DIR} -o ${WALSCRIPTS_DIR}/genzathurarc --saturate 0.85 -b "#323232" > /dev/null 2>&1

# switch to workspace (n)
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5

# move focused container to workspace (n)
bindsym $mod+Shift+1 move container to workspace number $ws1; workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2; workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3; workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4; workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5; workspace number $ws5

# reload the config
bindsym $mod+Shift+c reload

# restart i3 inplace (preserves layout/session)
bindsym $mod+Shift+r restart

# exit i3 (logs out of X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# resize window
bindsym $mod+r mode "resize"
mode "resize" {
    bindsym $left    resize shrink width 10 px or 10 ppt
    bindsym $down    resize grow height 10 px or 10 ppt
    bindsym $up      resize shrink height 10 px or 10 ppt
    bindsym $right   resize grow width 10 px or 10 ppt

    bindsym u        resize shrink width 5 px or 5 ppt
    bindsym i        resize grow height 5 px or 5 ppt
    bindsym o        resize shrink height 5 px or 5 ppt
    bindsym p        resize grow width 5 px or 5 ppt

    bindsym Return mode "default"
    bindsym $mod+r mode "default"
}

bar {
    position bottom
    mode dock
    tray_output primary
    tray_padding 4
    strip_workspace_numbers yes

    font pango: Font Awesome Mono 10
    separator_symbol " | "
    status_command I3SCRIPTS=~/Scripts/i3blocks/blocks i3blocks -c ~/.config/i3blocks/config

    colors {
        background #121212
        statusline #d8dee9
        separator #969696
    }
}

